# Application
APP_PORT=8080
APP_ENV=development
CORS_ORIGINS=*

# Database (PostgreSQL) — at least one is required
DATABASE_DSN=postgres://flowdo:secret@localhost:5432/flowdo_db?sslmode=disable
# DATABASE_URL=postgres://flowdo:secret@localhost:5432/flowdo_db?sslmode=disable

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_TTL=24h

# Postgres credentials (used by docker-compose)
POSTGRES_USER=flowdo
POSTGRES_PASSWORD=secret
POSTGRES_DB=flowdo_db
